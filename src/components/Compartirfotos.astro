<!-- ═══════════════════════════════════════════════════════════ --><!-- 📸 SECCIÓN: COMPARTE TUS FOTOS                             --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-10 pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-fotos">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-fotos">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- FLOR — esquina superior izquierda -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -top-7 left-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(-30%);"
                />

                <!-- FLOR — esquina inferior derecha -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -bottom-7 right-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(30%) rotate(180deg);"
                />

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-fotos"
                >
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo compartir fotos"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div
                        class="relative px-6 py-12 z-10 flex flex-col items-center"
                    >
                        <!-- ICONO CÁMARA -->
                        <div class="mb-6" id="icono-camara">
                            <div class="relative">
                                <div class="absolute -top-2 -right-3">
                                    <svg
                                        class="w-6 h-6"
                                        fill="#c48a9a"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
                                        ></path>
                                    </svg>
                                </div>
                                <div class="absolute -top-1 -left-2">
                                    <svg
                                        class="w-4 h-4"
                                        fill="#c48a9a"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
                                        ></path>
                                    </svg>
                                </div>

                                <img
                                    src="/imagenes/foto.png"
                                    alt="Cámara"
                                    class="w-24 h-24 object-contain icono-camara-color"
                                />

                                <div
                                    class="absolute bottom-2 -right-4 flex gap-1"
                                >
                                    <div
                                        class="w-1 h-1 rounded-full bg-[#5b9ab5]"
                                    >
                                    </div>
                                    <div
                                        class="w-1 h-1 rounded-full bg-[#5b9ab5]"
                                    >
                                    </div>
                                    <div
                                        class="w-1 h-1 rounded-full bg-[#5b9ab5]"
                                    >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- TÍTULO -->
                        <div class="text-center mb-4" id="titulo-fotos">
                            <h2
                                class="font-great-vibes text-[2.5rem] leading-tight fotos-titulo"
                            >
                                Comparte tus Fotos
                            </h2>
                        </div>

                        <!-- TEXTO -->
                        <div class="text-center mb-8" id="texto-fotos">
                            <p
                                class="font-crimson text-lg leading-relaxed fotos-texto"
                            >
                                Te invitamos a compartir<br />
                                tus fotografías de nuestra boda
                            </p>
                        </div>

                        <!-- BOTÓN -->
                        <div id="boton-compartir-fotos">
                            <a
                                href="https://photos.google.com/share/AF1QipPpQMIT9Xy6aXgj0uZA6rYUZqRjENYxQuTvnflfyMhZyq9Jrj_VGyhqlUMTHUYdFw?key=UjVIVkgybzZlQkwwMVo1Qk5RYlN0SWpsN2Etc21B"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-block px-10 py-3 border-2 font-crimson text-base uppercase tracking-wider rounded-full transition-all duration-300 hover:scale-105 fotos-btn"
                            >
                                Compartir Fotos
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-fotos",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-fotos",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#icono-camara",
                { opacity: 0, scale: 0.5, rotation: -10 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 0.8,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#titulo-fotos",
                { opacity: 0, y: -20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.2,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#texto-fotos",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.4,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#boton-compartir-fotos",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.6,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-fotos",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );
        });
    }
</script>

<style>
    /* Título — rosado pastel */
    .fotos-titulo {
        color: #c48a9a;
    }

    /* Texto — azul pastel */
    .fotos-texto {
        color: #5b9ab5;
    }

    /* Botón — azul pastel */
    .fotos-btn {
        color: #5b9ab5;
        border-color: #5b9ab5;
    }
    .fotos-btn:hover {
        background-color: #5b9ab5;
        color: #fff;
    }

    /* Icono cámara — azul pastel */
    .icono-camara-color {
        filter: brightness(0) saturate(100%) invert(55%) sepia(30%)
            saturate(600%) hue-rotate(165deg) brightness(95%) contrast(90%);
    }
</style>

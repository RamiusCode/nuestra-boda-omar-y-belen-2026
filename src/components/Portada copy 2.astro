---
// src/components/Portada.astro
// Diseño: paleta pastel azul celeste · Funcionalidad: igual al Componente 2
// Novios: Omar & Belén · 6 de junio de 2026
---

<!--
  ══════════════════════════════════════════════════════════
  NombresFlores.astro se renderiza aquí debajo (slot).
  La portada lo tapa con position:fixed.
  Al presionar el sobre: audio.play() + portada.remove() → contenido visible.
  ══════════════════════════════════════════════════════════
-->
<slot />

<!-- ══════════ PORTADA FIJA ══════════ -->
<section
    id="portada-section"
    class="fixed inset-0 w-full h-screen flex justify-center z-[10000] overflow-hidden"
    style="
        background-color:#eef4f8;
        background-image:
            radial-gradient(ellipse at 20% 10%,rgba(173,216,230,0.38) 0%,transparent 50%),
            radial-gradient(ellipse at 80% 90%,rgba(216,191,216,0.28) 0%,transparent 50%),
            radial-gradient(ellipse at 60% 40%,rgba(255,182,193,0.18) 0%,transparent 45%),
            url('/imagenes/BlancoTextura.webp');
        background-size:cover;
        background-position:center;
        background-repeat:no-repeat;
    "
>
    <!-- Burbujas decorativas de fondo -->
    <div class="burbuja b1"></div>
    <div class="burbuja b2"></div>
    <div class="burbuja b3"></div>
    <div class="burbuja b4"></div>

    <div class="relative w-full max-w-[480px]">
        <!-- Flores esquina superior -->
        <div class="absolute top-0 left-0 right-0 h-32 overflow-hidden z-[8]">
            <div id="flor-izq" class="absolute -top-2 -left-2 w-28 h-28">
                <img
                    src="/imagenes/floriz.webp"
                    alt=""
                    class="w-full h-full object-contain"
                    style="filter:hue-rotate(185deg) saturate(0.85) brightness(1.1);"
                />
            </div>
            <div id="flor-der" class="absolute -top-2 -right-2 w-28 h-28">
                <img
                    src="/imagenes/florde.webp"
                    alt=""
                    class="w-full h-full object-contain"
                    style="filter:hue-rotate(200deg) saturate(0.75) brightness(1.1);"
                />
            </div>
        </div>

        <!-- Hojas laterales (capa inferior) -->
        <img
            id="hoja-izq"
            src="/imagenes/hojadorada.png"
            alt=""
            class="absolute left-2 top-[47%] w-20 h-20 md:w-28 md:h-28 pointer-events-none z-[5]"
            style="filter:hue-rotate(165deg) saturate(1.2) brightness(1.1);"
        />
        <img
            id="hoja-der"
            src="/imagenes/hojadorada.png"
            alt=""
            class="absolute right-2 top-[47%] w-20 h-20 md:w-28 md:h-28 pointer-events-none z-[5] scale-x-[-1]"
            style="filter:hue-rotate(165deg) saturate(1.2) brightness(1.1);"
        />

        <!-- Flores laterales (capa superior) -->
        <img
            id="flor-lat-izq"
            src="/imagenes/florlateral.png"
            alt=""
            class="absolute left-0 top-[46%] w-20 h-20 md:w-28 md:h-28 pointer-events-none z-[6]"
            style="filter:hue-rotate(185deg) saturate(0.9) brightness(1.1);"
        />
        <img
            id="flor-lat-der"
            src="/imagenes/florlateral.png"
            alt=""
            class="absolute right-0 top-[46%] w-20 h-20 md:w-28 md:h-28 pointer-events-none z-[6] scale-x-[-1]"
            style="filter:hue-rotate(185deg) saturate(0.9) brightness(1.1);"
        />

        <!-- Contenido central -->
        <div class="relative z-10 pt-28 pb-2 px-6 flex flex-col items-center">
            <!-- Tagline -->
            <p
                id="tagline"
                class="text-[10px] tracking-[0.45em] uppercase font-medium mb-3 text-center"
                style="color:#8ab4c8; font-family:'Cormorant Garamond',serif;"
            >
                Una historia de amor
            </p>

            <!-- Título -->
            <h1
                id="titulo"
                class="text-xl text-center mb-5 tracking-[0.28em] font-semibold uppercase"
                style="font-family:'Cormorant Garamond',serif; color:#5b9ab5; text-shadow:0 1px 12px rgba(135,189,214,0.35);"
            >
                ¡Nos Casamos!
            </h1>

            <!-- Nombre Omar -->
            <div
                id="nombre-omar"
                class="text-[52px] leading-tight text-center mb-1"
                style="font-family:'Great Vibes',cursive; color:#4a8fa8;"
            >
                Omar
            </div>

            <!-- Separador & -->
            <div class="flex items-center justify-center gap-4 py-1 w-full">
                <div
                    id="linea-izq"
                    class="h-px flex-1 max-w-[80px]"
                    style="background:linear-gradient(to right,transparent,#87c1d6);"
                >
                </div>
                <span
                    id="ampersand"
                    class="text-3xl"
                    style="font-family:'Great Vibes',cursive; color:#87c1d6;"
                    >&</span
                >
                <div
                    id="linea-der"
                    class="h-px flex-1 max-w-[80px]"
                    style="background:linear-gradient(to left,transparent,#87c1d6);"
                >
                </div>
            </div>

            <!-- Nombre Belén -->
            <div
                id="nombre-belen"
                class="text-[52px] leading-tight text-center mt-1 mb-5"
                style="font-family:'Great Vibes',cursive; color:#4a8fa8;"
            >
                Belén
            </div>

            <!-- Fecha -->
            <div
                id="fecha"
                class="text-center mb-4"
                style="font-family:'Cormorant Garamond',serif; color:#6b9db5;"
            >
                <p class="text-xl tracking-widest font-medium">
                    Sábado · 6 de junio
                </p>
                <p
                    class="text-sm tracking-[0.3em] mt-1 uppercase"
                    style="opacity:0.7;"
                >
                    2026
                </p>
            </div>

            <!-- Pase para una persona -->
            <div id="pase" class="flex justify-center mb-5 w-full">
                <div class="pase-ticket">
                    <span class="pase-linea"></span>
                    <span class="pase-texto">✦ Pase para una persona ✦</span>
                    <span class="pase-linea"></span>
                </div>
            </div>

            <!-- SOBRE — clic aquí abre todo -->
            <div
                id="sobre-btn"
                class="flex justify-center mb-4 cursor-pointer select-none"
            >
                <div class="sobre-wrap">
                    <div class="sobre-glow"></div>
                    <img
                        src="/imagenes/sobre.webp"
                        alt="Abrir invitación"
                        class="w-[260px] relative z-[2]"
                        style="filter:drop-shadow(0 8px 24px rgba(90,170,210,0.45)) saturate(0.95) brightness(1.05);"
                    />
                    <div class="sobre-etiqueta">
                        <svg
                            width="11"
                            height="11"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.2"
                        >
                            <path d="M21.5 2L12 13.5 2.5 2"></path>
                            <path d="M2 2h20v16a2 2 0 01-2 2H4a2 2 0 01-2-2V2z"
                            ></path>
                        </svg>
                        <span>Tu invitación</span>
                    </div>
                </div>
            </div>

            <!-- Instrucción -->
            <p
                id="instruccion"
                class="text-center text-xs uppercase font-semibold tracking-[0.22em] px-4 pulso"
                style="font-family:'Cormorant Garamond',serif; color:#7ab3cc;"
            >
                Toca el sobre para abrir la invitación
            </p>

            <!-- Dots decorativos -->
            <div id="dots" class="flex justify-center gap-2 mt-3">
                <span class="dot" style="background:#87c1d6;"></span>
                <span
                    class="dot"
                    style="background:#c3d9e8;width:6px;height:6px;"></span>
                <span class="dot" style="background:#d4a5b5;"></span>
            </div>
        </div>
    </div>
</section>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap");

    body {
        overflow: hidden;
    } /* bloqueado hasta que se abra */

    /* Burbujas */
    .burbuja {
        position: fixed;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
    }
    .b1 {
        width: 280px;
        height: 280px;
        top: -80px;
        left: -80px;
        background: radial-gradient(
            circle,
            rgba(135, 193, 214, 0.22) 0%,
            transparent 70%
        );
    }
    .b2 {
        width: 220px;
        height: 220px;
        bottom: -60px;
        right: -60px;
        background: radial-gradient(
            circle,
            rgba(195, 165, 192, 0.18) 0%,
            transparent 70%
        );
    }
    .b3 {
        width: 160px;
        height: 160px;
        top: 40%;
        right: -40px;
        background: radial-gradient(
            circle,
            rgba(168, 200, 216, 0.14) 0%,
            transparent 70%
        );
    }
    .b4 {
        width: 120px;
        height: 120px;
        top: 30%;
        left: -30px;
        background: radial-gradient(
            circle,
            rgba(240, 192, 200, 0.14) 0%,
            transparent 70%
        );
    }

    /* Pase */
    .pase-ticket {
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px dashed rgba(135, 193, 214, 0.5);
        border-radius: 6px;
        padding: 7px 18px;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(4px);
    }
    .pase-texto {
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        letter-spacing: 0.3em;
        font-weight: 600;
        color: #7ab3cc;
        text-transform: uppercase;
        white-space: nowrap;
    }
    .pase-linea {
        flex: 1;
        height: 1px;
        min-width: 20px;
        background: linear-gradient(
            to right,
            transparent,
            rgba(135, 193, 214, 0.45),
            transparent
        );
    }

    /* Sobre */
    .sobre-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
    }
    .sobre-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 290px;
        height: 130px;
        border-radius: 50%;
        background: radial-gradient(
            ellipse,
            rgba(135, 193, 214, 0.45) 0%,
            transparent 70%
        );
        z-index: 1;
        pointer-events: none;
    }
    .sobre-etiqueta {
        position: absolute;
        bottom: -14px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(135, 193, 214, 0.55);
        border-radius: 20px;
        padding: 4px 14px;
        font-family: "Cormorant Garamond", serif;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.15em;
        color: #5b9ab5;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
        z-index: 10;
        box-shadow: 0 2px 10px rgba(90, 154, 181, 0.18);
    }

    /* Dots */
    .dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        opacity: 0.6;
    }

    /* Pulso instrucción */
    @keyframes pulso {
        0%,
        100% {
            opacity: 0.65;
        }
        50% {
            opacity: 1;
        }
    }
    .pulso {
        animation: pulso 2.5s ease-in-out infinite;
    }
</style>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        // ── Estado inicial: todo oculto ──────────────────────────
        gsap.set("#flor-izq", { opacity: 0, x: -60, scale: 0.8 });
        gsap.set("#flor-der", { opacity: 0, x: 60, scale: 0.8 });
        gsap.set("#tagline", { opacity: 0, y: -15 });
        gsap.set("#titulo", { opacity: 0, y: -25, scale: 0.95 });
        gsap.set("#nombre-omar", { opacity: 0, x: -40, scale: 0.9 });
        gsap.set("#nombre-belen", { opacity: 0, x: 40, scale: 0.9 });
        gsap.set("#linea-izq", { scaleX: 0, transformOrigin: "right" });
        gsap.set("#linea-der", { scaleX: 0, transformOrigin: "left" });
        gsap.set("#ampersand", { opacity: 0, scale: 0, rotation: -180 });
        gsap.set("#fecha", { opacity: 0, y: 20 });
        gsap.set("#pase", { opacity: 0, y: 12 });
        gsap.set("#sobre-btn", { opacity: 0, y: 28, scale: 0.9 });
        gsap.set("#instruccion", { opacity: 0 });
        gsap.set("#dots", { opacity: 0 });
        gsap.set("#hoja-izq", { opacity: 0, x: -30 });
        gsap.set("#hoja-der", { opacity: 0, x: 30, scaleX: -1 });
        gsap.set("#flor-lat-izq", { opacity: 0, x: -30 });
        gsap.set("#flor-lat-der", { opacity: 0, x: 30, scaleX: -1 });

        // ── Animación de entrada ─────────────────────────────────
        const tl = gsap.timeline({ delay: 0.35 });
        tl.to(
            "#flor-izq",
            { opacity: 1, x: 0, scale: 1, duration: 1.2, ease: "power2.out" },
            0,
        )
            .to(
                "#flor-der",
                {
                    opacity: 1,
                    x: 0,
                    scale: 1,
                    duration: 1.2,
                    ease: "power2.out",
                },
                0,
            )
            .to(
                "#tagline",
                { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" },
                0.1,
            )
            .to(
                "#titulo",
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1.1,
                    ease: "power2.out",
                },
                0.2,
            )
            .to(
                "#nombre-omar",
                {
                    opacity: 1,
                    x: 0,
                    scale: 1,
                    duration: 1.0,
                    ease: "power2.out",
                },
                0.4,
            )
            .to(
                "#nombre-belen",
                {
                    opacity: 1,
                    x: 0,
                    scale: 1,
                    duration: 1.0,
                    ease: "power2.out",
                },
                0.4,
            )
            .to(
                "#linea-izq",
                { scaleX: 1, duration: 0.8, ease: "power2.out" },
                0.55,
            )
            .to(
                "#linea-der",
                { scaleX: 1, duration: 0.8, ease: "power2.out" },
                0.55,
            )
            .to(
                "#ampersand",
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 0.8,
                    ease: "back.out(1.5)",
                },
                0.65,
            )
            .to(
                "#flor-lat-izq",
                { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
                0.55,
            )
            .to(
                "#flor-lat-der",
                { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
                0.55,
            )
            .to(
                "#hoja-izq",
                { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
                0.75,
            )
            .to(
                "#hoja-der",
                { opacity: 1, x: 0, duration: 1.2, ease: "power2.out" },
                0.75,
            )
            .to(
                "#fecha",
                { opacity: 1, y: 0, duration: 1.0, ease: "power2.out" },
                1.1,
            )
            .to(
                "#pase",
                { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
                1.25,
            )
            .to(
                "#sobre-btn",
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1.0,
                    ease: "power2.out",
                },
                1.3,
            )
            .to(
                "#instruccion",
                { opacity: 1, duration: 0.8, ease: "power2.out" },
                1.5,
            )
            .to(
                "#dots",
                { opacity: 1, duration: 0.6, ease: "power2.out" },
                1.6,
            );

        // ── Flotación natural de flores y hojas ──────────────────
        tl.add(() => {
            gsap.to("#flor-izq", {
                y: -4,
                x: -2,
                rotation: -3,
                duration: 4.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-der", {
                y: -3.5,
                x: 2,
                rotation: 3,
                duration: 5.0,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-izq", {
                scale: 0.94,
                duration: 5.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-der", {
                scale: 0.94,
                duration: 6.0,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-lat-izq", {
                y: -10,
                x: -5,
                rotation: -8,
                duration: 3.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-lat-der", {
                y: -8,
                x: 5,
                rotation: 8,
                duration: 3.8,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-lat-izq", {
                x: -8,
                duration: 5.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#flor-lat-der", {
                x: 8,
                duration: 6.0,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#hoja-izq", {
                y: -12,
                rotation: -10,
                duration: 4.0,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#hoja-der", {
                y: -11,
                rotation: 10,
                scaleX: -0.85,
                scaleY: 0.85,
                duration: 4.3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
            gsap.to("#hoja-izq", {
                scale: 0.85,
                duration: 4.5,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
            });
        }, 2);

        // ── Hover sobre ──────────────────────────────────────────
        const sobreBtn = document.getElementById("sobre-btn");
        sobreBtn?.addEventListener("mouseenter", () =>
            gsap.to("#sobre-btn", {
                y: -10,
                scale: 1.05,
                duration: 0.3,
                ease: "power2.out",
            }),
        );
        sobreBtn?.addEventListener("mouseleave", () =>
            gsap.to("#sobre-btn", {
                y: 0,
                scale: 1,
                duration: 0.3,
                ease: "power2.out",
            }),
        );

        // ── CLICK EN EL SOBRE ────────────────────────────────────
        sobreBtn?.addEventListener("click", () => {
            // PASO 1: Reproducir música — DENTRO del click (los browsers lo permiten aquí)
            const audio = new Audio("/musica/melodia.mp3");
            audio.loop = true;
            audio.volume = 0.5;
            audio.play().catch((err: any) => console.warn("Audio:", err));

            // Guardar referencia para NombresFlores.astro
            (window as any).audioGlobal = audio;
            (window as any).estaReproduciendoGlobal = true;

            // Actualizar íconos del controlador de música
            setTimeout(() => {
                document.getElementById("icono-play")?.classList.add("hidden");
                document
                    .getElementById("icono-pause")
                    ?.classList.remove("hidden");
            }, 100);

            // PASO 2: Matar animaciones flotantes
            [
                "#flor-izq",
                "#flor-der",
                "#flor-lat-izq",
                "#flor-lat-der",
                "#hoja-izq",
                "#hoja-der",
            ].forEach((id) => gsap.killTweensOf(id));

            // PASO 3: Animación de salida + fade-out portada + remove()
            // NombresFlores ya está en el DOM renderizado debajo — queda expuesto al remover la portada
            const portada = document.getElementById("portada-section");

            gsap.timeline()
                .to("#sobre-btn", {
                    scale: 1.1,
                    duration: 0.18,
                    ease: "power2.in",
                })
                .to(
                    [
                        "#instruccion",
                        "#dots",
                        "#pase",
                        "#fecha",
                        "#nombre-belen",
                        "#nombre-omar",
                        "#ampersand",
                        "#linea-izq",
                        "#linea-der",
                        "#titulo",
                        "#tagline",
                    ],
                    {
                        opacity: 0,
                        y: -18,
                        duration: 0.32,
                        stagger: 0.022,
                        ease: "power2.in",
                    },
                    0.08,
                )
                .to(
                    [
                        "#flor-izq",
                        "#flor-der",
                        "#flor-lat-izq",
                        "#flor-lat-der",
                        "#hoja-izq",
                        "#hoja-der",
                    ],
                    {
                        opacity: 0,
                        scale: 0.8,
                        duration: 0.32,
                        ease: "power2.in",
                    },
                    0.08,
                )
                .to(
                    "#sobre-btn",
                    {
                        opacity: 0,
                        scale: 1.3,
                        duration: 0.32,
                        ease: "power2.in",
                    },
                    0.22,
                )
                .to(
                    portada,
                    {
                        opacity: 0,
                        duration: 0.8, // mismo timing que Componente 2
                        ease: "power2.out", // mismo easing que Componente 2
                        onStart() {
                            document.body.style.overflow = "auto"; // scroll ON
                        },
                        onComplete() {
                            portada?.remove(); // eliminar del DOM — igual que Componente 2
                            window.scrollTo({ top: 0, behavior: "smooth" });
                        },
                    },
                    0.42,
                );
        }); // fin click
    }); // fin DOMContentLoaded
</script>

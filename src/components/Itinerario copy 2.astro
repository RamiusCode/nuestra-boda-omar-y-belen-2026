<!-- ═══════════════════════════════════════════════════════════ --><!-- 📅 SECCIÓN: ITINERARIO                                      --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[280px]" id="card-itinerario">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-itinerario">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-itinerario"
                >
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo itinerario"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div class="relative px-6 py-10 z-10">
                        <!-- TÍTULO -->
                        <div class="text-center mb-8">
                            <h2
                                class="font-crimson text-[1.75rem] uppercase tracking-[0.3em] font-semibold"
                                id="titulo-itinerario"
                            >
                                ITINERARIO
                            </h2>
                        </div>

                        <!-- EVENTO 1: CEREMONIA RELIGIOSA -->
                        <div class="flex items-start gap-4 mb-5" id="evento-1">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/iglesia.png"
                                    alt="Ceremonia Religiosa"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Ceremonia Religiosa
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    15:30 PM
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 2: CEREMONIA CIVIL Y RECEPCIÓN -->
                        <div class="flex items-start gap-4 mb-5" id="evento-2">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/recepcion.png"
                                    alt="Ceremonia Civil"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Ceremonia Civil y Recepción
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    4:00 PM
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 3: BRINDIS -->
                        <div class="flex items-start gap-4 mb-5" id="evento-3">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/brindis.png"
                                    alt="Brindis"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Brindis
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    6:00 PM
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 4: CENA -->
                        <div class="flex items-start gap-4 mb-5" id="evento-4">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/cena.png"
                                    alt="Cena"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Cena
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    7:00 PM
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 5: FIESTA Y BAILE -->
                        <div class="flex items-start gap-4 mb-5" id="evento-5">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/musica.png"
                                    alt="Fiesta y Baile"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Fiesta y Baile
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    8:30 PM
                                </p>
                            </div>
                        </div>

                        <!-- EVENTO 6: DESPEDIDA -->
                        <div class="flex items-start gap-4" id="evento-6">
                            <div class="w-12 flex-shrink-0 mt-1">
                                <img
                                    src="/imagenes/despedida.png"
                                    alt="Despedida"
                                    class="w-full h-auto object-contain icono-itinerario"
                                />
                            </div>
                            <div class="flex-1 text-center">
                                <h3
                                    class="font-great-vibes text-[1.75rem] leading-none mb-1 titulo-evento"
                                >
                                    Despedida
                                </h3>
                                <p class="font-crimson text-base hora-evento">
                                    2:00 AM
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Título ITINERARIO — azul pastel */
    #titulo-itinerario {
        color: #5b9ab5;
    }

    /* Nombres de eventos — rosado pastel (Great Vibes) */
    .titulo-evento {
        color: #c48a9a;
    }

    /* Horas — azul pastel */
    .hora-evento {
        color: #5b9ab5;
    }

    /* Iconos — azul pastel */
    .icono-itinerario {
        filter: brightness(0) saturate(100%) invert(55%) sepia(30%)
            saturate(600%) hue-rotate(165deg) brightness(95%) contrast(90%);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-itinerario",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-itinerario",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#titulo-itinerario",
                { opacity: 0, y: -20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-itinerario",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            [
                "#evento-1",
                "#evento-2",
                "#evento-3",
                "#evento-4",
                "#evento-5",
                "#evento-6",
            ].forEach((evento, index) => {
                gsap.fromTo(
                    evento,
                    { opacity: 0, x: -30 },
                    {
                        opacity: 1,
                        x: 0,
                        duration: 0.6,
                        ease: "power2.out",
                        delay: index * 0.1,
                        scrollTrigger: {
                            trigger: "#card-itinerario",
                            start: "top 80%",
                            once: true,
                        },
                    },
                );
            });
        });
    }
</script>

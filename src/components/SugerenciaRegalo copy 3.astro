<!-- ═══════════════════════════════════════════════════════════ --><!-- 🎁 SECCIÓN: SUGERENCIA DE REGALES                           --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-regalos">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-regalos">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- FLOR DECORATIVA — esquina superior izquierda (fuera de la card) -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -top-7 left-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(-30%);"
                />

                <!-- FLOR DECORATIVA — esquina inferior derecha (fuera de la card) -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -bottom-7 right-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(30%) rotate(180deg);"
                />

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-regalos"
                >
                    <img
                        src="/imagenes/azul.png"
                        alt="Fondo mesa regalos"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div
                        class="relative px-4 py-12 z-10 flex flex-col items-center"
                    >
                        <!-- TÍTULO -->
                        <div class="text-center mb-6" id="titulo-regalos">
                            <h2
                                class="font-great-vibes text-[2.25rem] leading-tight regalos-titulo"
                            >
                                Sugerencia de Regalos
                            </h2>
                        </div>

                        <!-- TEXTO -->
                        <div class="text-center mb-8" id="texto-regalos">
                            <p
                                class="font-cormorant text-xl leading-relaxed regalos-texto"
                            >
                                El mejor regalo es tu presencia, pero si deseas
                                tener un detalle con nosotros, te dejamos esta
                                opción
                            </p>
                        </div>

                        <!-- QR CODE -->
                        <div class="mb-4 bg-white p-3 rounded-lg" id="qr-code">
                            <img
                                src="/imagenes/qr.png"
                                alt="QR Mesa de Regalos"
                                class="w-56 h-56 object-contain"
                            />
                        </div>

                        <!-- NÚMERO DE CUENTA -->
                        <div id="numero-cuenta" class="text-center">
                            <p
                                class="font-cormorant text-lg font-semibold tracking-wide regalos-cuenta"
                            >
                                CTA: 3500466153
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger } from "gsap/ScrollTrigger";

        gsap.registerPlugin(ScrollTrigger);

        if (typeof window !== "undefined") {
            document.addEventListener("DOMContentLoaded", () => {
                gsap.fromTo(
                    "#boton-decorativo-regalos",
                    { opacity: 0, scale: 0, rotation: -180 },
                    {
                        opacity: 1,
                        scale: 1,
                        rotation: 0,
                        duration: 1,
                        ease: "back.out(1.7)",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                gsap.fromTo(
                    "#card-principal-regalos",
                    { opacity: 0, y: 50, scale: 0.95 },
                    {
                        opacity: 1,
                        y: 0,
                        scale: 1,
                        duration: 1,
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                gsap.fromTo(
                    "#titulo-regalos",
                    { opacity: 0, y: -20 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                gsap.fromTo(
                    "#texto-regalos",
                    { opacity: 0, y: 20 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        delay: 0.2,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                gsap.fromTo(
                    "#qr-code",
                    { opacity: 0, scale: 0.8 },
                    {
                        opacity: 1,
                        scale: 1,
                        duration: 0.8,
                        delay: 0.4,
                        ease: "back.out(1.7)",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );

                gsap.fromTo(
                    "#numero-cuenta",
                    { opacity: 0, y: 20 },
                    {
                        opacity: 1,
                        y: 0,
                        duration: 0.8,
                        delay: 0.6,
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: "#card-regalos",
                            start: "top 80%",
                            toggleActions: "play none none none",
                        },
                    },
                );
            });
        }
    </script>
</section>

<style>
    /* Título — rosado pastel */
    .regalos-titulo {
        color: #c48a9a;
    }

    /* Texto descriptivo — azul pastel */
    .regalos-texto {
        color: #5b9ab5;
    }

    /* Número de cuenta — rosado pastel */
    .regalos-cuenta {
        color: #c48a9a;
    }
</style>

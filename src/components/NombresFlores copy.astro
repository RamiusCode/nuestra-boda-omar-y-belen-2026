<!-- ═══════════════════════════════════════════════════════════ --><!-- 💌 SECCIÓN: SOBRE CON FOTO + TARJETAS                       --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-8 pb-4 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-2 sm:px-6 lg:px-8">

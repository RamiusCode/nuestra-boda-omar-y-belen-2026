            id="sobre-container"
        >
            <div
                class="relative w-full max-w-xs sm:max-w-sm md:max-w-md lg:max-w-lg"
            >
                <img
                    src="/imagenes/carta.webp"
                    alt="Sobre con foto de los novios"
                    class="w-full h-auto object-contain drop-shadow-2xl"
                    id="sobre-imagen"
                />
            </div>
        </div>

        <!-- 📇 TARJETAS (Dos tarjetas lado a lado - SIEMPRE en horizontal) -->
        <div
            class="relative w-full flex flex-row justify-center items-start gap-3 sm:gap-6 md:gap-12 lg:gap-16"
            id="tarjetas-container"
        >
            <!-- 📇 TARJETA IZQUIERDA (Fecha/Guardar la fecha) -->
            <div
                class="relative w-1/2 max-w-[160px] xs:max-w-[160px] sm:max-w-[200px] md:max-w-[240px] lg:max-w-[260px] mt-8 sm:mt-8 md:mt-12"
                id="tarjeta-izquierda"
            >
                <div
                    class="relative rounded-sm shadow-xl overflow-hidden h-full"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo tarjeta"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Overlay opcional -->
                    <div class="absolute inset-0 bg-white/40"></div>

                    <!-- Decoración superior -->
                    <div
                        class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-white/20 to-transparent"
                    >
                    </div>

                    <!-- Contenido de la tarjeta -->
                    <div
                        class="relative p-6 sm:p-6 md:p-8 h-full flex flex-col justify-between min-h-[320px] xs:min-h-[360px] sm:min-h-[420px] md:min-h-[480px] z-10"
                    >
                        <!-- ARRIBA: GUARDA LA FECHA -->
                        <div class="w-full">
                            <p
                                class="font-crimson text-base xs:text-lg sm:text-xl md:text-2xl text-[#122a4d] leading-tight text-left"
                            >
                                GUARDA <br />LA FECHA
                            </p>
                        </div>

                        <!-- CENTRO: FECHA -->
                        <div
                            class="w-full flex-grow flex flex-col justify-center items-center"
                        >
                            <p
                                class="font-charm pb-1 text-5xl xs:text-6xl sm:text-7xl md:text-8xl text-[#122a4d] font-bold leading-none"
                            >
                                06
                            </p>
                            <p
                                class="font-great-vibes text-3xl xs:text-4xl sm:text-5xl md:text-6xl text-[#122a4d] mt-1 pb-1"
                            >
                                de Junio
                            </p>
                            <p
                                class="font-charm text-base sm:text-base text-[#122a4d] mt-1"
                            >
                                2026
                            </p>
                        </div>

                        <!-- ABAJO: CELEBRACIÓN JUNTOS -->
                        <div class="w-full">
                            <p
                                class="font-crimson text-base xs:text-[10px] sm:text-xs text-[#122a4d] uppercase tracking-widest leading-tight text-right"
                            >
                                CELEBREMOS<br />JUNTOS
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 📇 TARJETA DERECHA (Nombres) -->
            <div
                class="relative w-1/2 max-w-[160px] xs:max-w-[160px] sm:max-w-[200px] md:max-w-[240px] lg:max-w-[260px]"
                id="tarjeta-derecha"
            >
                <div
                    class="relative rounded-sm shadow-xl overflow-hidden h-full"
                >
                    <!-- IMAGEN DE FONDO -->
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo tarjeta"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <!-- Overlay opcional -->
                    <div class="absolute inset-0 bg-white/20"></div>

                    <!-- Textura de papel -->
                    <div
                        class="absolute inset-0 opacity-10"
                        style="background-image: url('data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' /%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.3'/%3E%3C/svg%3E');"
                    >
                    </div>

                    <!-- Contenido de la tarjeta -->
                    <div
                        class="relative p-6 sm:p-6 md:p-8 text-center flex flex-col justify-center min-h-[320px] xs:min-h-[360px] sm:min-h-[420px] md:min-h-[480px] z-10"
                    >
                        <div class="mb-6 sm:mb-6">
                            <p
                                class="font-crimson text-base xs:text-[10px] sm:text-xs md:text-sm text-[#122a4d] uppercase tracking-widest mb-2 sm:mb-4"
                            >
                                Nos Casamos
                            </p>
                        </div>

                        <h3
                            class="font-great-vibes text-4xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-[#122a4d] mb-2 sm:mb-3"
                        >
                            Omar
                        </h3>

                        <div
                            class="text-[#122a4d] text-3xl xs:text-2xl sm:text-3xl md:text-4xl font-charm my-2 sm:my-3"
                        >
                            y
                        </div>

                        <h3
                            class="font-great-vibes text-4xl xs:text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-[#122a4d] mt-2 sm:mt-3"
                        >
                            Belén
                        </h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 🎵 CONTROL DE MÚSICA FLOTANTE -->
<div
    id="music-control"
    title="Controlar música"
    style="
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9000;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,0.92);
        border: 1.5px solid rgba(135,193,214,0.6);
        box-shadow: 0 4px 18px rgba(90,154,181,0.22), 0 1px 4px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transform: scale(0.7);
        transition: box-shadow 0.2s, background 0.2s;
        backdrop-filter: blur(8px);
    "
>
    <!-- Ícono Play -->
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
        style="display:none; margin-left:2px;"
    >
        <path d="M8 5v14l11-7z"/>
    </svg>
    <!-- Ícono Pause -->
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
        style="display:none;"
    >
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
    </svg>
    <!-- Ícono nota musical (estado inicial: sin audio aún) -->
    <svg
        id="icono-nota"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
    >
        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
    </svg>
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        console.log("💌 Iniciando animaciones del sobre y tarjetas...");

        // ═══ ANIMACIÓN DEL SOBRE ═══
        gsap.fromTo(
            "#sobre-imagen",
            {
                opacity: 0,
                y: -100,
                scale: 0.8,
                rotation: -5,
            },
            {
                opacity: 1,
                y: 0,
                scale: 1,
                rotation: 0,
                duration: 1.2,
                ease: "back.out(1.3)",
                scrollTrigger: {
                    trigger: "#sobre-container",
                    start: "top 80%",
                    toggleActions: "play none none none",
                },
            },
        );

        // Efecto de flotación continua en el sobre
        gsap.to("#sobre-imagen", {
            y: -10,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.2,
        });

        // ═══ ANIMACIÓN TARJETA IZQUIERDA ═══
        gsap.fromTo(
            "#tarjeta-izquierda",
            {
                opacity: 0,
                x: -100,
            },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                delay: 0.3,
            },
        );

        // ═══ ANIMACIÓN TARJETA DERECHA ═══
        gsap.fromTo(
            "#tarjeta-derecha",
            {
                opacity: 0,
                x: 100,
            },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                delay: 0.5,
            },
        );

        // ═══ CONTROL DE MÚSICA ═══
        const musicBtn = document.getElementById("music-control") as HTMLElement | null;
        const iconoPlay   = document.getElementById("icono-play")   as HTMLElement | null;
        const iconoPause  = document.getElementById("icono-pause")  as HTMLElement | null;
        const iconoNota   = document.getElementById("icono-nota")   as HTMLElement | null;

        // Función para actualizar los íconos según el estado del audio
        function actualizarIconos(reproduciendo: boolean) {
            if (iconoNota)  iconoNota.style.display  = "none";
            if (reproduciendo) {
                if (iconoPlay)  iconoPlay.style.display  = "none";
                if (iconoPause) iconoPause.style.display = "block";
            } else {
                if (iconoPlay)  iconoPlay.style.display  = "block";
                if (iconoPause) iconoPause.style.display = "none";
            }
        }

        // Escuchar cuando la portada inicia el audio y lo guarda en window.audioGlobal
        // Usamos un polling ligero para detectar cuando audioGlobal esté disponible
        let checkInterval: ReturnType<typeof setInterval> | null = null;
        checkInterval = setInterval(() => {
            if ((window as any).audioGlobal) {
                clearInterval(checkInterval!);
                // El audio ya está corriendo → mostrar botón con ícono pause
                gsap.to(musicBtn, { opacity: 1, scale: 1, duration: 0.5, ease: "back.out(1.5)" });
                actualizarIconos(true);
            }
        }, 200);

        // Click en el botón de música
        musicBtn?.addEventListener("click", () => {
            const audio = (window as any).audioGlobal as HTMLAudioElement | undefined;
            if (!audio) return;

            if (audio.paused) {
                audio.play().catch(() => {});
                (window as any).estaReproduciendoGlobal = true;
                actualizarIconos(true);
            } else {
                audio.pause();
                (window as any).estaReproduciendoGlobal = false;
                actualizarIconos(false);
            }
        });

        // Hover sutil en el botón
        musicBtn?.addEventListener("mouseenter", () => {
            gsap.to(musicBtn, { scale: 1.12, duration: 0.2, ease: "power2.out" });
        });
        musicBtn?.addEventListener("mouseleave", () => {
            gsap.to(musicBtn, { scale: 1, duration: 0.2, ease: "power2.out" });
        });

        console.log("✨ Animaciones del sobre completadas!");
    });
</script>

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- 🎨 ESTILOS CSS                                              -->
<!-- ═══════════════════════════════════════════════════════════ -->
<style>
    /* Perspectiva 3D para las tarjetas */
    #tarjetas-container {
        perspective: 1000px;
    }

    /* Efecto hover en tarjetas */
    #tarjeta-izquierda > div,
    #tarjeta-derecha > div {
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    #tarjeta-izquierda > div:hover,
    #tarjeta-derecha > div:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }
</style>

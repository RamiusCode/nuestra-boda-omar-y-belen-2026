<!-- ═══════════════════════════════════════════════════════════ --><!-- 🎫 SECCIÓN: PASES ASIGNADOS                                 --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-20s
pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-pases">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-pases">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- FLOR — esquina superior izquierda -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -top-7 left-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(-30%);"
                />

                <!-- FLOR — esquina inferior derecha -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -bottom-7 right-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(30%) rotate(180deg);"
                />

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-pases"
                >
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo pases"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div class="relative px-6 py-10 z-10">
                        <!-- ÍCONO TICKET -->
                        <div class="flex justify-center mb-4" id="icono-pases">
                            <img
                                src="/imagenes/ticket.png"
                                alt="Ticket"
                                class="w-14 h-auto mx-auto icono-pases-img"
                            />
                        </div>

                        <!-- TÍTULO -->
                        <div class="text-center mb-5" id="titulo-pases">
                            <p
                                class="font-crimson text-sm uppercase tracking-widest font-semibold pases-subtitulo"
                            >
                                PASES ASIGNADOS
                            </p>
                            <div
                                class="flex items-center justify-center gap-2 my-3"
                            >
                                <div
                                    class="h-px w-12 bg-current opacity-30 pases-linea"
                                >
                                </div>
                                <div
                                    class="w-1.5 h-1.5 rounded-full pases-punto"
                                >
                                </div>
                                <div
                                    class="h-px w-12 bg-current opacity-30 pases-linea"
                                >
                                </div>
                            </div>
                        </div>

                        <!-- NÚMERO DE PASES -->
                        <div class="text-center mb-2" id="numero-pases">
                            <p
                                class="font-great-vibes text-[5rem] leading-none pases-numero"
                            >
                                1
                            </p>
                            <p
                                class="font-crimson text-sm uppercase tracking-widest font-semibold mt-1 pases-subtitulo"
                            >
                                PASE
                            </p>
                        </div>

                        <!-- Separador inferior -->
                        <div
                            class="flex items-center justify-center gap-2 my-4"
                        >
                            <div class="h-px w-12 opacity-30 pases-linea-div">
                            </div>
                            <div class="w-1.5 h-1.5 rounded-full pases-punto">
                            </div>
                            <div class="h-px w-12 opacity-30 pases-linea-div">
                            </div>
                        </div>

                        <!-- MENSAJE -->
                        <div class="text-center mb-6" id="mensaje-pases">
                            <p
                                class="font-crimson text-lg leading-relaxed italic pases-nota"
                            >
                                Esperamos contar con<br />tu presencia
                            </p>
                        </div>

                        <!-- ÍCONOS DE PERSONAS -->
                        <div
                            class="flex justify-center gap-3"
                            id="personas-pases"
                        >
                            <div
                                class="w-10 h-10 rounded-full pases-avatar-bg flex items-center justify-center"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    class="w-5 h-5 pases-avatar-icon"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0zM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <!-- <div
                                class="w-10 h-10 rounded-full pases-avatar-bg flex items-center justify-center"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    class="w-5 h-5 pases-avatar-icon"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0zM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div> -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .icono-pases-img {
        filter: brightness(0) saturate(100%) invert(55%) sepia(30%)
            saturate(600%) hue-rotate(165deg) brightness(95%) contrast(90%);
    }
    .pases-subtitulo {
        color: #5b9ab5;
    }
    .pases-numero {
        color: #c48a9a;
    }
    .pases-nota {
        color: #c48a9a;
    }
    .pases-punto {
        background-color: #5b9ab5;
    }
    .pases-linea-div {
        background-color: #5b9ab5;
    }
    .pases-avatar-bg {
        background-color: rgba(91, 154, 181, 0.15);
    }
    .pases-avatar-icon {
        color: #5b9ab5;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-pases",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-pases",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#icono-pases",
                { opacity: 0, scale: 0.5 },
                {
                    opacity: 1,
                    scale: 1,
                    duration: 0.8,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#titulo-pases",
                { opacity: 0, y: -20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#numero-pases",
                { opacity: 0, scale: 0.5 },
                {
                    opacity: 1,
                    scale: 1,
                    duration: 0.8,
                    delay: 0.2,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#mensaje-pases",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.6,
                    delay: 0.4,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#personas-pases",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.6,
                    delay: 0.6,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-pases",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );
        });
    }
</script>

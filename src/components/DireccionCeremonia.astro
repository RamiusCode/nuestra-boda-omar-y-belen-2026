<!-- ═══════════════════════════════════════════════════════════ --><!-- ⛪ SECCIÓN: CEREMONIA                                       --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-4 pb-12 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div
                class="relative w-full max-w-md sm:max-w-lg md:max-w-xl"
                id="card-ceremonia"
            >
                <div
                    class="relative rounded-2xl shadow-xl overflow-hidden"
                    style="background-color: #e8dcc8;"
                >
                    <img
                        src="/imagenes/fondorojo.png"
                        alt="Fondo ceremonia"
                        class="absolute inset-0 w-full h-full object-cover opacity-90"
                    />

                    <div
                        class="relative px-4 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 z-10"
                    >
                        <div class="mb-4">
                            <h2
                                class="font-great-vibes text-4xl sm:text-4xl md:text-5xl text-center"
                                id="titulo-ceremonia"
                            >
                                Ceremonia Religiosa
                            </h2>
                            <div class="titulo-separador">
                                <span class="titulo-linea"></span>
                                <span class="titulo-rombo">✦</span>
                                <span class="titulo-linea"></span>
                            </div>
                            <h2
                                class="font-great-vibes text-3xl sm:text-3xl md:text-4xl text-center"
                                id="titulo-recepcion"
                            >
                                Recepción Social
                            </h2>
                        </div>

                        <div class="flex items-center justify-between gap-4">
                            <!-- ICONO IGLESIA -->
                            <div class="flex-shrink-0 ml-4 sm:ml-6 md:ml-8">
                                <div
                                    class="w-24 h-24 sm:w-20 sm:h-20 md:w-24 md:h-24 icono-iglesia-color"
                                >
                                    <img
                                        src="/imagenes/iglesia.png"
                                        alt="Iglesia"
                                        class="w-full h-full object-contain"
                                        id="icono-iglesia"
                                    />
                                </div>
                            </div>

                            <!-- TEXTOS -->
                            <div class="flex-1 text-center">
                                <div class="mb-2">
                                    <p
                                        class="font-crimson text-xl sm:text-lg md:text-xl font-semibold"
                                        id="nombre-parroquia"
                                    >
                                        Hotel Ecoresort<br />La Colina
                                    </p>
                                </div>

                                <div class="mb-4">
                                    <p
                                        class="font-crimson text-xl sm:text-base md:text-lg leading-tight font-semibold"
                                        id="hora-ceremonia"
                                    >
                                        Hora: 15:30
                                    </p>
                                </div>

                                <!-- BOTÓN VER UBICACIÓN -->
                                <div class="mt-4">
                                    <a
                                        href="https://maps.app.goo.gl/khjBCMEfAQRFqZzdA"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-block px-4 py-2 sm:px-6 sm:py-2.5 border-2 rounded-full font-crimson text-base sm:text-sm uppercase tracking-wider transition-all duration-300 btn-ubicacion-ceremonia font-semibold"
                                        id="btn-ubicacion"
                                    >
                                        VER UBICACIÓN
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#card-ceremonia",
                { opacity: 0, scale: 0.85, y: 60, rotationY: -15 },
                {
                    opacity: 1,
                    scale: 1,
                    y: 0,
                    rotationY: 0,
                    duration: 1.2,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-ceremonia",
                        start: "top 80%",
                        once: true,
                    },
                },
            );
        });
    }
</script>

<style>
    #titulo-ceremonia {
        color: #5b9ab5;
    }
    #titulo-recepcion {
        color: #5b9ab5;
    }
    #nombre-parroquia {
        color: #c48a9a;
    }
    #hora-ceremonia {
        color: #5b9ab5;
    }

    .titulo-separador {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin: 4px auto 4px;
        max-width: 180px;
    }
    .titulo-linea {
        flex: 1;
        height: 1px;
        background: linear-gradient(
            to right,
            transparent,
            rgba(196, 138, 154, 0.4),
            transparent
        );
    }
    .titulo-rombo {
        font-size: 11px;
        color: #c48a9a;
        opacity: 0.6;
    }

    .icono-iglesia-color {
        filter: brightness(0) saturate(100%) invert(55%) sepia(30%)
            saturate(600%) hue-rotate(165deg) brightness(95%) contrast(90%);
    }

    .btn-ubicacion-ceremonia {
        color: #5b9ab5;
        border-color: #5b9ab5;
    }

    #card-ceremonia > div {
        transition: all 0.4s ease;
        transform-style: preserve-3d;
    }
</style>

<!-- ═══════════════════════════════════════════════════════════ --><!-- 👥 SECCIÓN: ACOMPAÑANTES (SIN NIÑOS)                        --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full pt-20 pb-10 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[280px]" id="card-acompanantes">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div class="w-16 h-16" id="boton-decorativo-acompanantes">
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- FLOR — esquina superior izquierda -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -top-7 left-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(-30%);"
                />

                <!-- FLOR — esquina inferior derecha -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -bottom-7 right-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(30%) rotate(180deg);"
                />

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-acompanantes"
                >
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo acompañantes"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div
                        class="relative px-4 py-12 z-10 flex flex-col items-center justify-center min-h-[200px]"
                    >
                        <div class="text-center" id="texto-acompanantes">
                            <p
                                class="font-crimson text-xl leading-relaxed acomp-texto"
                            >
                                Aunque amamos a sus pequeños este día especial
                                es solo para Adultos, le pedimos venga
                                acompañado <br />
                                <span class="font-bold acomp-acento"
                                    >SIN NIÑOS.</span
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-acompanantes",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-acompanantes",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );

            gsap.fromTo(
                "#texto-acompanantes",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.3,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-acompanantes",
                        start: "top 80%",
                        toggleActions: "play none none none",
                    },
                },
            );
        });
    }
</script>

<style>
    /* Texto principal — azul pastel */
    .acomp-texto {
        color: #5b9ab5;
    }

    /* "SIN NIÑOS" — rosado pastel destacado */
    .acomp-acento {
        color: #c48a9a;
    }
</style>

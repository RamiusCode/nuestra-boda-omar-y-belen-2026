<!-- 🎬 ANIMACIONES CON GSAP                                     -->
<!-- ═══════════════════════════════════════════════════════════ -->
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        // ═══ SOBRE ═══
        gsap.fromTo(
            "#sobre-imagen",
            { opacity: 0, y: -100, scale: 0.8, rotation: -5 },
            {
                opacity: 1,
                y: 0,
                scale: 1,
                rotation: 0,
                duration: 1.2,
                ease: "back.out(1.3)",
                scrollTrigger: {
                    trigger: "#sobre-container",
                    start: "top 80%",
                    toggleActions: "play none none none",
                },
            },
        );

        // Flotación suave del sobre (se mantiene)
        gsap.to("#sobre-imagen", {
            y: -10,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.2,
        });

        // ═══ TARJETA IZQUIERDA ═══
        gsap.fromTo(
            "#tarjeta-izquierda",
            { opacity: 0, x: -100 },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                delay: 0.3,
            },
        );

        // ═══ TARJETA DERECHA ═══
        gsap.fromTo(
            "#tarjeta-derecha",
            { opacity: 0, x: 100 },
            {
                opacity: 1,
                x: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: {
                    trigger: "#tarjetas-container",
                    start: "top 75%",
                    toggleActions: "play none none none",
                },
                delay: 0.5,
            },
        );

        // ═══ CONTROL DE MÚSICA ═══
        const musicBtn = document.getElementById(
            "music-control",
        ) as HTMLElement | null;
        const iconoPlay = document.getElementById(
            "icono-play",
        ) as HTMLElement | null;
        const iconoPause = document.getElementById(
            "icono-pause",
        ) as HTMLElement | null;
        const iconoNota = document.getElementById(
            "icono-nota",
        ) as HTMLElement | null;

        function actualizarIconos(reproduciendo: boolean) {
            if (iconoNota) iconoNota.style.display = "none";
            if (reproduciendo) {
                if (iconoPlay) iconoPlay.style.display = "none";
                if (iconoPause) iconoPause.style.display = "block";
            } else {
                if (iconoPlay) iconoPlay.style.display = "block";
                if (iconoPause) iconoPause.style.display = "none";
            }
        }

        let checkInterval: ReturnType<typeof setInterval> | null = null;
        checkInterval = setInterval(() => {
            if ((window as any).audioGlobal) {
                clearInterval(checkInterval!);
                gsap.to(musicBtn, {
                    opacity: 1,
                    scale: 1,
                    duration: 0.5,
                    ease: "back.out(1.5)",
                });
                actualizarIconos(true);
            }
        }, 200);

        musicBtn?.addEventListener("click", () => {
            const audio = (window as any).audioGlobal as
                | HTMLAudioElement
                | undefined;
            if (!audio) return;
            if (audio.paused) {
                audio.play().catch(() => {});
                (window as any).estaReproduciendoGlobal = true;
                actualizarIconos(true);
            } else {
                audio.pause();
                (window as any).estaReproduciendoGlobal = false;
                actualizarIconos(false);
            }
        });

        musicBtn?.addEventListener("mouseenter", () =>
            gsap.to(musicBtn, {
                scale: 1.12,
                duration: 0.2,
                ease: "power2.out",
            }),
        );
        musicBtn?.addEventListener("mouseleave", () =>
            gsap.to(musicBtn, { scale: 1, duration: 0.2, ease: "power2.out" }),
        );
    });
</script>


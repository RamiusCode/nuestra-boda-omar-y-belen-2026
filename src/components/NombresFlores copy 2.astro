<!-- 🎵 CONTROL DE MÚSICA FLOTANTE -->
<div
    id="music-control"
    title="Controlar música"
    style="
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9000;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,0.92);
        border: 1.5px solid rgba(135,193,214,0.6);
        box-shadow: 0 4px 18px rgba(90,154,181,0.22), 0 1px 4px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transform: scale(0.7);
        transition: box-shadow 0.2s, background 0.2s;
        backdrop-filter: blur(8px);
    "
>
    <svg
        id="icono-play"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
        style="display:none; margin-left:2px;"
    >
        <path d="M8 5v14l11-7z"></path>
    </svg>
    <svg
        id="icono-pause"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
        style="display:none;"
    >
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
    </svg>
    <svg
        id="icono-nota"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="#5b9ab5"
    >
        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"></path>
    </svg>
</div>


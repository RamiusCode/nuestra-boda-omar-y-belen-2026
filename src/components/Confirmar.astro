<!-- ═══════════════════════════════════════════════════════════ --><!-- 💬 SECCIÓN: CONFIRMA TU ASISTENCIA                         --><!-- ═══════════════════════════════════════════════════════════ -->
<section class="relative w-full py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-center">
            <div class="relative w-[300px]" id="card-confirmar">
                <!-- BOTÓN DECORATIVO SUPERIOR -->
                <div
                    class="absolute z-20"
                    style="top: -30px; left: 50%; transform: translateX(-50%);"
                >
                    <div
                        class="w-16 h-16 sm:w-20 sm:h-20"
                        id="boton-decorativo-confirmar"
                    >
                        <img
                            src="/imagenes/boton.png"
                            alt="Decoración"
                            class="w-full h-full object-contain"
                        />
                    </div>
                </div>

                <!-- FLOR — esquina superior izquierda -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -top-7 left-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(-30%);"
                />

                <!-- FLOR — esquina inferior derecha -->
                <img
                    src="/imagenes/floradorno.png"
                    alt=""
                    class="absolute -bottom-7 right-0 w-36 pointer-events-none z-[25]"
                    style="transform: translateX(30%) rotate(180deg);"
                />

                <!-- CARD PRINCIPAL -->
                <div
                    class="relative rounded-[40px] shadow-xl overflow-hidden bg-[#f5f5f5]"
                    id="card-principal-confirmar"
                >
                    <img
                        src="/imagenes/fondoplomo.png"
                        alt="Fondo confirmar"
                        class="absolute inset-0 w-full h-full object-cover"
                    />

                    <div
                        class="relative px-6 py-12 sm:px-8 sm:py-14 z-10 flex flex-col items-center justify-center"
                    >
                        <!-- TÍTULO -->
                        <div class="text-center mb-6" id="titulo-confirmar">
                            <h2
                                class="font-crimson text-2xl sm:text-3xl md:text-4xl uppercase tracking-wide font-bold confirmar-titulo"
                            >
                                Confirma Tu<br />Asistencia
                            </h2>
                        </div>

                        <!-- TEXTO -->
                        <div class="text-center mb-8" id="texto-confirmar">
                            <p
                                class="font-crimson text-xl sm:text-lg leading-relaxed confirmar-texto"
                            >
                                Será de mucha alegría<br />
                                para nosotros contar<br />
                                con tu compañía en este<br />
                                día tan importante.
                            </p>
                        </div>

                        <!-- BOTÓN -->
                        <div
                            class="flex justify-center"
                            id="boton-formulario-confirmar"
                        >
                            <a
                                href="https://wa.link/6e7719"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center justify-center gap-2 px-2 py-3 border-2 font-crimson text-base uppercase tracking-wider rounded-full transition-all duration-300 hover:scale-105 whitespace-nowrap confirmar-btn"
                                aria-label="Confirmar asistencia"
                            >
                                <svg
                                    class="w-5 h-5 flex-shrink-0"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path>
                                </svg>
                                <span class="font-semibold"
                                    >Confirmar asistencia</span
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.fromTo(
                "#boton-decorativo-confirmar",
                { opacity: 0, scale: 0, rotation: -180 },
                {
                    opacity: 1,
                    scale: 1,
                    rotation: 0,
                    duration: 1,
                    ease: "back.out(1.7)",
                    scrollTrigger: {
                        trigger: "#card-confirmar",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#card-principal-confirmar",
                { opacity: 0, y: 50, scale: 0.95 },
                {
                    opacity: 1,
                    y: 0,
                    scale: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: "#card-confirmar",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#titulo-confirmar",
                { opacity: 0, y: -20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.3,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-confirmar",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#texto-confirmar",
                { opacity: 0, y: 20 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.5,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: "#card-confirmar",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.fromTo(
                "#boton-formulario-confirmar",
                { opacity: 0, scale: 0.8, y: 20 },
                {
                    opacity: 1,
                    scale: 1,
                    y: 0,
                    duration: 0.8,
                    delay: 0.7,
                    ease: "back.out(1.5)",
                    scrollTrigger: {
                        trigger: "#card-confirmar",
                        start: "top 80%",
                        once: true,
                    },
                },
            );

            gsap.to("#boton-decorativo-confirmar", {
                y: -5,
                duration: 2,
                ease: "sine.inOut",
                yoyo: true,
                repeat: -1,
                delay: 1,
            });

            gsap.to("#boton-formulario-confirmar a", {
                y: -3,
                duration: 2,
                ease: "sine.inOut",
                yoyo: true,
                repeat: -1,
                delay: 1,
            });
        });
    }
</script>

<style>
    .confirmar-titulo {
        color: #5b9ab5;
    }
    .confirmar-texto {
        color: #5b9ab5;
    }

    /* Botón — borde rosado, sin fondo */
    .confirmar-btn {
        color: #c48a9a;
        border-color: #c48a9a;
    }
    .confirmar-btn:hover {
        background-color: rgba(196, 138, 154, 0.08);
    }

    #card-principal-confirmar {
        transition: all 0.4s ease;
    }
    #card-principal-confirmar:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(91, 154, 181, 0.2);
    }
    #boton-formulario-confirmar a:active {
        outline: none;
        transform: scale(0.95);
    }
</style>
